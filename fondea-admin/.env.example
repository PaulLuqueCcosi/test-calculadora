# Backend API URL
# Cambia esta URL según tu entorno
VITE_API_BASE_URL=http://localhost:8080/api

# Endpoint para envíos de contacto del landing
# Este endpoint se usa para listar los mensajes de contacto del landing page
VITE_LANDING_CONTACT_ENDPOINT=/v1/landing/contact

